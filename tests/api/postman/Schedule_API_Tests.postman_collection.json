{
  "info": {
    "name": "Schedule API Tests",
    "_postman_id": "schedule-api-tests-collection",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Teachers",
      "item": [
        {
          "name": "GET All Teachers",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/teachers"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', () => pm.response.to.have.status(200));",
                  "pm.test('Response is array', () => {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body).to.be.an('array');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "GET Teacher by ID",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/teachers/{{teacherId}}"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', () => pm.response.to.have.status(200));",
                  "pm.test('Teacher has id', () => {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body).to.have.property('id');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "POST Create Teacher",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/teachers",
            "body": {
              "mode": "raw",
              "raw": "{\"name\":\"{{teacherName}}\",\"surname\":\"{{teacherSurname}}\",\"patronymic\":\"{{teacherPatronymic}}\",\"position\":\"доцент\",\"department\":{\"id\":1}}"
            }
          },
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "const ts = Date.now();",
                  "pm.environment.set('teacherName', 'Name' + ts);",
                  "pm.environment.set('teacherSurname', 'Surname' + ts);",
                  "pm.environment.set('teacherPatronymic', 'Patron' + ts);"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 201', () => pm.response.to.have.status(201));",
                  "pm.test('Returns created teacher with id', () => {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body).to.have.property('id');",
                  "  pm.environment.set('teacherId', body.id);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "PUT Update Teacher",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/teachers",
            "body": {
              "mode": "raw",
              "raw": "{\"id\":{{teacherId}},\"name\":\"Updated\",\"surname\":\"UpdatedSurname\",\"patronymic\":\"UpdatedPat\",\"position\":\"професор\",\"department\":{\"id\":1}}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', () => pm.response.to.have.status(200));",
                  "pm.test('Name is updated', () => {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body.name).to.eql('Updated');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "DELETE Teacher",
          "request": {
            "method": "DELETE",
            "url": "{{baseUrl}}/teachers/{{teacherId}}"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', () => pm.response.to.have.status(200));",
                  "pm.test('Response is truthy', () => {",
                  "  pm.expect(pm.response.text()).to.not.be.empty;",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "GET Non-existing Teacher (404)",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/teachers/999999"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 404', () => pm.response.to.have.status(404));",
                  "pm.test('Error message present', () => {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body).to.have.property('message');",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
    {
