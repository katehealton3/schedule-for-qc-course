                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "GET Subject by ID",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/subjects/{{subjectId}}"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', () => pm.response.to.have.status(200));",
                  "pm.test('Subject has name', () => {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body).to.have.property('name');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "GET Non-existing Subject (404)",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/subjects/999999"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 404', () => pm.response.to.have.status(404));",
                  "pm.test('Error body present', () => {",
                  "  pm.expect(pm.response.json()).to.have.property('message');",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
